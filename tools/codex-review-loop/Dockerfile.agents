# Both agents in one image. Bind-mount your repo and run the loop inside.
#
#   docker build -t agents -f Dockerfile.agents .
#   cd /path/to/your/repo
#   docker run --rm -it \
#     -v "$PWD":/work \
#     -v claude-auth:/root/.claude \
#     -v codex-auth:/root/.codex \
#     agents bash
#   # first run inside the container: `claude` login, then `codex login`

FROM node:24-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
      git curl less jq ca-certificates ripgrep bubblewrap \
    && rm -rf /var/lib/apt/lists/*

# The claude package name is stable. If the codex install ever fails, confirm the
# current command from OpenAI's Codex CLI docs.
RUN npm install -g @anthropic-ai/claude-code @openai/codex

WORKDIR /work
