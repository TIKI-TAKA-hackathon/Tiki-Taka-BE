# Postgres
POSTGRES_DB=gojjibom
POSTGRES_USER=gojjibom
POSTGRES_PASSWORD=change-me-strong-password

# Comma-separated origins allowed to call the API - the exact frontend origins
# (scheme + host, no trailing slash, no path). For Firebase Hosting these are the
# project's default domains: https://<project>.web.app and https://<project>.firebaseapp.com.
# Keep http://localhost:5173 for local Vite dev. Replace YOUR-PROJECT with the real Firebase project id.
APP_CORS_ALLOWED_ORIGINS=http://localhost:5173,https://YOUR-PROJECT.web.app,https://YOUR-PROJECT.firebaseapp.com

# Optional HTTPS public API base URL for OpenAPI servers. Set this in production secrets/env.
APP_PUBLIC_BASE_URL=

# Object storage for images (Phase 5). The bucket MUST be private.
# In prod, prefer an EC2 IAM role (no keys) - then set only bucket + region below.
AWS_S3_BUCKET=your-private-bucket
AWS_REGION=ap-northeast-2
AWS_S3_PATH_STYLE_ACCESS=false
# Static credentials - uncomment ONLY if you are NOT using an EC2 IAM role.
# Leave commented to let the AWS SDK pick up the instance role (recommended in prod).
#AWS_ACCESS_KEY_ID=
#AWS_SECRET_ACCESS_KEY=
# MinIO / other S3-compatible storage - uncomment to target a self-hosted endpoint.
#AWS_S3_ENDPOINT=http://minio:9000

# Media limits / URL TTLs
APP_MEDIA_MAX_IMAGE_BYTES=5242880
APP_MEDIA_UPLOAD_URL_TTL_SECONDS=300
APP_MEDIA_VIEW_URL_TTL_SECONDS=300
